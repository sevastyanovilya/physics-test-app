<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Основная тема приложения — Material3, зелёная палитра -->
    <style name="Theme.PhysicsTest" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/green_medium</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Тема для SplashActivity — зелёный фон -->
    <style name="Theme.PhysicsTest.Splash" parent="Theme.PhysicsTest">
        <item name="android:windowBackground">@color/green_primary</item>
        <item name="android:statusBarColor">@color/green_primary</item>
        <item name="android:navigationBarColor">@color/green_primary</item>
    </style>

    <!-- Стиль для основных зелёных кнопок -->
    <style name="Widget.PhysicsTest.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_size_medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/padding_large</item>
        <item name="android:paddingEnd">@dimen/padding_large</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="backgroundTint">@null</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Стиль для второстепенных кнопок (контурных) -->
    <style name="Widget.PhysicsTest.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textSize">@dimen/text_size_medium</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="strokeColor">@color/green_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
    </style>

    <!-- Стиль для кнопок вариантов ответов -->
    <style name="Widget.PhysicsTest.Button.Option" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_option_normal</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">@dimen/padding_medium</item>
        <item name="android:paddingEnd">@dimen/padding_medium</item>
        <item name="backgroundTint">@null</item>
        <item name="cornerRadius">@dimen/corner_radius_medium</item>
    </style>

    <!-- Заголовки карточек -->
    <style name="TextAppearance.PhysicsTest.Title">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Основной текст вопроса -->
    <style name="TextAppearance.PhysicsTest.QuestionText">
        <item name="android:textSize">@dimen/text_size_large</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>
