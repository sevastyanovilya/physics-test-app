<?xml version="1.0" encoding="utf-8"?>
<!--
    Фон для кнопки варианта ответа в нормальном состоянии.
    Белый фон с тонкой серой рамкой — выглядит как карточка.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Нажатое состояние — светло-зелёный фон -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#C8E6C9" />
            <stroke android:width="1.5dp" android:color="#2E7D32" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Нормальное состояние — белый с серой рамкой -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <stroke android:width="1dp" android:color="#E0E0E0" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
