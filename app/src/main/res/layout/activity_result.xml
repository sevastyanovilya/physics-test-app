<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_large"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_medium"
            android:text="✅ Тест завершён!"
            android:textSize="@dimen/text_size_headline"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvGradeResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="9 класс"
            android:textSize="@dimen/text_size_medium"
            android:textColor="@color/text_secondary" />

        <!-- Карточка с баллами -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_large"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:gravity="center"
            android:elevation="@dimen/card_elevation">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Правильных ответов"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 / 15"
                android:textSize="48sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textSize="@dimen/text_size_title"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Уровень знаний -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_medium"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="@dimen/padding_medium"
            android:gravity="center_vertical"
            android:elevation="@dimen/card_elevation">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Уровень знаний:"
                android:textSize="@dimen/text_size_medium"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvLevelBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/padding_small"
                android:paddingEnd="@dimen/padding_small"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Базовый"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_option_selected" />

        </LinearLayout>

        <!-- Секция с кодом результата -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_medium"
            android:background="@color/green_light"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 Код для репетитора"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/green_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvResultCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="123456"
                android:textSize="40sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.3" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Назовите этот код репетитору или покажите QR-код ниже"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/green_dark"
                android:gravity="center" />

        </LinearLayout>

        <!-- QR-код -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_medium"
            android:text="📱 QR-код для сканирования:"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

        <FrameLayout
            android:layout_width="@dimen/qr_code_size"
            android:layout_height="@dimen/qr_code_size"
            android:layout_marginTop="@dimen/padding_small">

            <ProgressBar
                android:id="@+id/progressQr"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_primary"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="QR-код результата"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Скрытое поле для уровня (используется из кода) -->
        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="Базовый" />

        <!-- Кнопка нового теста -->
        <Button
            android:id="@+id/btnNewTest"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_large"
            android:text="Пройти ещё раз"
            android:background="@drawable/button_primary"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_medium"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
